{
	"name": "@aphexcms/blog",
	"version": "0.0.8",
	"packageManager": "pnpm@10.18.3",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --force --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"mail": "docker compose up -d mailpit",
		"mail:stop": "docker compose stop mailpit",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"generate:types": "aphex generate:types ./src/lib/schemaTypes/index.ts ./src/lib/generated-types.ts ./src/lib/plugins.ts",
		"test": "vitest run",
		"test:verbose": "vitest run --reporter=verbose",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:local": "vitest run comprehensive-local-api",
		"test:http": "vitest run comprehensive-http-api",
		"test:graphql": "vitest run comprehensive-graphql-api",
		"test:all": "vitest run comprehensive",
		"test:coverage": "vitest run --coverage",
		"test:date": "tsx scripts/test-date-localapi.ts"
	},
	"dependencies": {
		"@aphexcms/cms-core": "^9.6.0",
		"@aphexcms/nodemailer-adapter": "^15.0.1",
		"@aphexcms/plugin-color-picker": "^0.1.0",
		"@aphexcms/plugin-seo": "^0.1.0",
		"@aphexcms/resend-adapter": "^14.0.1",
		"@aphexcms/sqlite-adapter": "^0.2.0",
		"@aphexcms/storage-s3": "^14.0.1",
		"@aphexcms/ui": "^0.8.3",
		"@aphexcms/visual-editing": "^0.2.0",
		"@better-auth/api-key": "^1.5.3",
		"@better-auth/drizzle-adapter": "^1.5.3",
		"@envelop/graphql-jit": "^11.0.0",
		"@graphql-yoga/render-graphiql": "^5.16.2",
		"@libsql/client": "^0.15.15",
		"@portabletext/svelte": "^3.0.1",
		"@shikijs/core": "^4.3.1",
		"@shikijs/engine-javascript": "^4.3.1",
		"@shikijs/langs": "^4.3.1",
		"@shikijs/themes": "^4.3.1",
		"better-auth": "^1.5.3",
		"better-svelte-email": "^1.4.0",
		"drizzle-orm": "^0.45.2",
		"graphql": "^16.12.0",
		"graphql-yoga": "^5.16.2",
		"kysely": "0.28.5",
		"mode-watcher": "^1.1.0",
		"sharp": "^0.34.5",
		"svelte-sonner": "^1.0.7"
	},
	"devDependencies": {
		"@hono/zod-validator": "^0.7.6",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.554.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^22.0.0",
		"@vitest/ui": "^4.0.14",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"dotenv": "^17.2.3",
		"drizzle-kit": "^0.31.7",
		"hono": "^4.12.15",
		"mdsvex": "^0.12.6",
		"svelte": "^5.55.5",
		"svelte-check": "^4.3.4",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.20.6",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^8.1.5",
		"vitest": "^4.0.14",
		"zod": "^4.3.6"
	}
}
