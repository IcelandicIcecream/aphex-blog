# ============================
# Database Configuration (SQLite via libsql)
# ============================

## Zero config: with no DATABASE_URL set, the blog uses a local SQLite file at
## .aphex/blog.db (gitignored). Migrations run automatically on boot.
# DATABASE_URL="file:.aphex/blog.db"

## Turso-hosted SQLite (managed hosting):
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# ============================
# Auth Configuration
# ============================
# BETTER_AUTH_SECRET / BETTER_AUTH_URL also work for backwards compatibility
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production
BETTER_AUTH_URL=http://localhost:5173
AUTH_TRUSTED_ORIGINS=http://localhost:5173

## Email verification is OFF by default (self-hosted apps like Dokploy/WordPress
## don't force it, and it blocks the first signup without a deliverable SMTP/
## Mailpit server). Opt in for production by uncommenting the line below — without
## it, anyone can sign up with an address they don't own (and the first user
## becomes super admin).
# AUTH_REQUIRE_EMAIL_VERIFICATION=true

# ============================
# Resend Email Configuration (optional)
# ============================
RESEND_API_KEY=re_your_api_key_here

# Outbound sender identity. Read server-side by the email config; overrides the built-in
# default in src/lib/email-sender.ts. Set to your own verified sender for production.
# APHEX_EMAIL_FROM=Acme <onboarding@example.com>

# ============================
# S3_COMPATIBLE CONFIGURATION (optional)
# ============================
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
# Optional: custom CDN domain (overrides R2_PUBLIC_URL for asset URLs)
# R2_CDN_URL=https://cdn.yourdomain.com
